# ─── Qwen Cloud (LLM inference via OpenAI-compatible API) ───
# Used by packages/server (OpenAICompatibleAdapter in OfficeRoom.ts).
# Get a key from Alibaba Cloud Model Studio / DashScope.
QWEN_API_KEY=
# DashScope OpenAI-compatible base (the adapter appends "/v1/chat/completions").
# International: https://dashscope-intl.aliyuncs.com/compatible-mode
# Mainland China: https://dashscope.aliyuncs.com/compatible-mode
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode
# Qwen model id, e.g. qwen-plus, qwen-max, qwen-turbo.
QWEN_MODEL=qwen-plus

# Tavily API key (optional) — enables Tavily web search for agents.
# When set, web_search calls use Tavily; otherwise DuckDuckGo is used as fallback.
# Get your key at https://app.tavily.com
TAVILY_API_KEY=
